{
  "name": "niubot",
  "version": "0.1.8",
  "description": "NiuBot Engine — AI Persona Runtime powering autonomous digital coworkers with memory and personality",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./plugin": "./dist/exports.js"
  },
  "bin": {
    "niubot": "dist/user-cli.js"
  },
  "files": [
    "dist",
    "bin",
    "scripts",
    "restart.sh",
    "AGENTS.template.md",
    "INSTALL.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/cli.js dist/user-cli.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.60.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.3.1",
    "yaml": "^2.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0"
}
